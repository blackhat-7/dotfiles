{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "external_directory": "allow",
    "websearch": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "read": "allow",
    "task": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "cloudsql-reader_*": "allow",
    "mongo-reader_*": "allow",
    "stage-mongo-reader_*": "allow",
    "grafana-loki-reader_*": "allow",
    "sentry-reader_*": "allow",
    "chrome-devtools_*": "allow",
    "playwright_*": "allow",
    "linear_*": "allow",
    "github_*": "allow",
    "arxiv_*": "allow",
    "bestiary_*": "allow",
    "skill": {
      "*": "allow"
    }
  },
  "provider": {
    "local-llm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local LLM",
      "options": {
        "baseURL": "http://100.64.0.1:6868/v1/",
        "apiKey": "none"
      },
      "models": {
        "qwen3.5-9b": {
          "name": "qwen3.5-9b"
        },
        "gemma-4-26B-A4B": {
          "name": "gemma-4-26B-A4B"
        }
      }
    }
  },
  "small_model": "github-copilot/gpt-5-mini",
  "mcp": {
    "cloudsql-reader": {
      "type": "local",
      "command": [
        "env-cmd",
        "-f",
        "{env:HOME}/Documents/Work/Editing/aftershoot-cloud/env/dev/cloudsql-reader/app.env",
        "{env:HOME}/Documents/Work/Editing/aftershoot-cloud/dist/mcp-servers/cloudsql-reader"
      ],
      "enabled": true
    },
    "grafana-loki-reader": {
      "type": "local",
      "command": [
        "env-cmd",
        "-f",
        "{env:HOME}/Documents/Work/Editing/aftershoot-cloud/env/dev/grafana-loki-reader/app.env",
        "{env:HOME}/Documents/Work/Editing/aftershoot-cloud/dist/mcp-servers/grafana-loki-reader"
      ],
      "enabled": false
    },
    "mongo-reader": {
      "type": "local",
      "command": [
        "env-cmd",
        "-f",
        "{env:HOME}/Documents/Work/Editing/aftershoot-cloud/env/dev/mongo-reader/app.env",
        "{env:HOME}/Documents/Work/Editing/aftershoot-cloud/dist/mcp-servers/mongo-reader"
      ],
      "enabled": false
    },
    "stage-mongo-reader": {
      "type": "local",
      "command": [
        "env-cmd",
        "-f",
        "{env:HOME}/Documents/Work/Editing/aftershoot-cloud/env/dev/mongo-reader/stage-app.env",
        "{env:HOME}/Documents/Work/Editing/aftershoot-cloud/dist/mcp-servers/mongo-reader"
      ],
      "enabled": false
    },

    "sentry-reader": {
      "type": "local",
      "command": [
        "env-cmd",
        "-f",
        "{env:HOME}/Documents/Work/Editing/aftershoot-cloud/env/dev/sentry-reader/app.env",
        "{env:HOME}/Documents/Work/Editing/aftershoot-cloud/dist/mcp-servers/sentry-reader"
      ],
      "enabled": false
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": false
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_MCP_TOKEN}"
      },
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": false
    },
    "arxiv": {
      "type": "local",
      "command": ["arxiv-mcp-server"],
      "environment": {
        "ARXIV_STORAGE_PATH": "~/Downloads/papers"
      },
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": false
    },
    "bestiary": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/blackhat-7/bestiary.git@main",
        "bestiary",
        "serve"
      ],
      "enabled": true
    }
  }
}
